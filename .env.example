# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Mailchimp
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_SERVER_PREFIX=your_server_prefix_here # e.g., us1
MAILCHIMP_LIST_ID=your_list_id_here

# Twilio (WhatsApp/SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=whatsapp:+14155238886 # Example Twilio Sandbox number
TO_PHONE_NUMBER=whatsapp:+1234567890

# SMTP config for Email notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
TO_EMAIL=destination_email@example.com

# Database
DATABASE_URL=sqlite:///leads.db
